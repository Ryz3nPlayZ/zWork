# 1. Main API Subdomain
api.tryzwork.app {
    handle /api/auth/desktop/google* {
        reverse_proxy axum_api:8080
    }

    handle /api/auth/callback/google* {
        reverse_proxy axum_api:8080
    }

    # Auth endpoints (Better Auth) — must come before /api/* catch-all
    handle /api/auth/* {
        reverse_proxy better_auth:3000
    }

    # Health check at root
    handle /health {
        reverse_proxy axum_api:8080
    }

    # Root path also shows health
    handle / {
        reverse_proxy axum_api:8080
    }

    # Axum API & AI Proxy
    handle /api/* {
        reverse_proxy axum_api:8080
    }
}

# 2. Database Management (disabled by default)
db.tryzwork.app {
    respond "disabled" 403
}

# 3. Analytics Shortcut
analytics.tryzwork.app {
    redir https://us.posthog.com/project/397748?
}

# 4. Web App
app.tryzwork.app {
    root * /var/www/app.tryzwork.app
    encode gzip

    handle /api/* {
        reverse_proxy axum_api:8080
    }

    handle {
        try_files {path} /index.html
        file_server
    }
}
